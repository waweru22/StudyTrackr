# Database -- get this from Supabase > Settings > Database > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Flask secret key -- set any long random string
SECRET_KEY=your-secret-key-here

# Flask environment
FLASK_ENV=development

# JWT secret key -- set any long random string
JWT_SECRET_KEY=your-jwt-secret-key-here

# Mail Settings (Gmail App Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-gmail@gmail.com

# Frontend URL (used in verification links)
FRONTEND_URL=http://localhost:5173

# Admin registration key
SECRET_ADMIN_KEY=your-admin-key-here
